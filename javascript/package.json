{
  "name": "@erghi/sdk",
  "version": "1.0.0",
  "description": "Official JavaScript/TypeScript SDK for the Erghi customer-support platform",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ai",
    "chat",
    "chatbot",
    "sdk",
    "typescript",
    "websocket",
    "real-time"
  ],
  "author": "Erghi Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ErghiPlatform/erghi-sdks"
  },
  "bugs": {
    "url": "https://github.com/ErghiPlatform/erghi-sdks/issues"
  },
  "homepage": "https://erghi.ai",
  "dependencies": {
    "axios": "^1.7.9",
    "eventemitter3": "^5.0.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/ws": "^8.5.13",
    "@typescript-eslint/eslint-plugin": "^8.18.1",
    "@typescript-eslint/parser": "^8.18.1",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
