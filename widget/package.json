{
  "name": "@erghi/widget",
  "version": "1.0.0",
  "description": "Embeddable chat widget for websites - Vanilla JS, no dependencies",
  "main": "dist/widget.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "webpack --mode production",
    "build:portal": "npm run build && cp dist/widget.js ../../Erghi/erghi-user-portal/public/widget.js",
    "dev": "webpack --mode development --watch",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint src --ext .ts"
  },
  "keywords": [
    "erghi",
    "chat",
    "widget",
    "embed",
    "customer-support",
    "live-chat"
  ],
