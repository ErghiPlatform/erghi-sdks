  "repository": {
    "type": "git",
    "url": "https://github.com/ErghiPlatform/erghi-sdks"
  },
  "devDependencies": {
    "@microsoft/signalr": "^8.0.7",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.2",
    "@typescript-eslint/eslint-plugin": "^8.18.1",
    "@typescript-eslint/parser": "^8.18.1",
    "css-loader": "^7.1.2",
    "eslint": "^9.17.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "style-loader": "^4.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.1",
    "typescript": "^5.7.2",
    "webpack": "^5.97.1",
    "webpack-cli": "^6.0.1"
  },
  "dependencies": {
    "@microsoft/signalr": "^8.0.7"
  }
